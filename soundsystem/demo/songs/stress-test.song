# PixelSynth DAW song (format 2)
# CPU stress test: all 8 tracks active, every effect enabled, 32 voices

[song]
format = 2
songName = "stress-test"
bpm = 120
stepCount = 16
grooveSwing = 0
grooveJitter = 0

[scale]
enabled = false
root = 0
type = 0

[groove]
