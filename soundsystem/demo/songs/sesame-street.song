# PixelSynth DAW song (format 2)
# 70s Sesame Street / Children's TV funk-jazz
# Think Joe Raposo, "Rubber Duckie", "People In Your Neighborhood"
# Funky fretless bass, breathy recorder melody, DX7 Rhodes chords, bongos

[song]
format = 2
songName = "Sesame Street Funk"
bpm = 112
stepCount = 16
grooveSwing = 0
grooveJitter = 0

[scale]
enabled = true
root = 0
type = 1

[groove]
kickNudge = 0
snareDelay = 2
hatNudge = 0
clapDelay = 0
swing = 5
jitter = 1
trackSwing0 = 5
trackSwing1 = 5
trackSwing2 = 5
trackSwing3 = 5
trackSwing4 = 5
trackSwing5 = 5
trackSwing6 = 5
trackSwing7 = 5
trackSwing8 = 5
trackSwing9 = 5
trackSwing10 = 5
trackSwing11 = 5
melodyTimingJitter = 1
melodyVelocityJitter = 0.05

[settings]
masterVol = 0.25
voiceRandomVowel = false

