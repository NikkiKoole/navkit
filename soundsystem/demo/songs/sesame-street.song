# ========================================
# Arrangement: A A B B A C B A
# ========================================
[arrangement]
length = 8
loopsPerPattern = 1
songMode = true
patterns = 0 0 1 1 0 2 1 0
loops = 0 0 0 0 0 0 0 0

# ========================================
# Pattern 0 — Verse A (bouncy, happy C major)
# ========================================
[pattern.0]
drumTrackLength = 16 16 16 16
melodyTrackLength = 16 16 16
# Kick: beats 1 and 3
d track=0 step=0 vel=0.45
d track=0 step=8 vel=0.4
# Brush snare: beats 2 and 4
d track=1 step=4 vel=0.3
d track=1 step=12 vel=0.35
# Shaker: steady 8th notes (alternating velocity)
d track=2 step=0 vel=0.25
d track=2 step=2 vel=0.15
d track=2 step=4 vel=0.25
d track=2 step=6 vel=0.15
d track=2 step=8 vel=0.25
d track=2 step=10 vel=0.15
d track=2 step=12 vel=0.25
d track=2 step=14 vel=0.15
# Bongo: syncopated, just before beats
d track=3 step=3 vel=0.35
d track=3 step=7 vel=0.25
d track=3 step=11 vel=0.35
d track=3 step=15 vel=0.2
# Bass: walking line C-E-F-G-A-G-E-D
m track=0 step=0 note=C3 vel=0.55 gate=4
m track=0 step=4 note=E3 vel=0.5 gate=2
m track=0 step=6 note=F3 vel=0.5 gate=2
m track=0 step=8 note=G3 vel=0.55 gate=4
m track=0 step=10 note=A3 vel=0.45 gate=2 slide
m track=0 step=12 note=G3 vel=0.5 gate=2
m track=0 step=14 note=E3 vel=0.45 gate=2
# Recorder melody: skippy, singable
m track=1 step=0 note=E5 vel=0.5 gate=4
m track=1 step=4 note=G5 vel=0.5 gate=4
m track=1 step=8 note=A5 vel=0.45 gate=2
m track=1 step=10 note=B5 vel=0.45 gate=2
m track=1 step=12 note=C6 vel=0.55 gate=4
# DX7 E.Piano chord stabs (offbeat, funky)
m track=2 step=1 note=C4 vel=0.4 gate=2
m track=2 step=1 note=E4 vel=0.4 gate=2
m track=2 step=1 note=G4 vel=0.4 gate=2
m track=2 step=5 note=C4 vel=0.35 gate=2
m track=2 step=5 note=E4 vel=0.35 gate=2
m track=2 step=5 note=G4 vel=0.35 gate=2
m track=2 step=9 note=F4 vel=0.4 gate=2
m track=2 step=9 note=A4 vel=0.4 gate=2
m track=2 step=9 note=C5 vel=0.4 gate=2
m track=2 step=13 note=G3 vel=0.4 gate=2
m track=2 step=13 note=B3 vel=0.4 gate=2
m track=2 step=13 note=D4 vel=0.4 gate=2

# ========================================
# Pattern 1 — Chorus (brighter, more energy)
# ========================================
[pattern.1]
drumTrackLength = 16 16 16 16
melodyTrackLength = 16 16 16
# Kick: syncopated, more drive
d track=0 step=0 vel=0.5
d track=0 step=6 vel=0.35
d track=0 step=8 vel=0.5
d track=0 step=14 vel=0.3
# Snare: louder backbeat
d track=1 step=4 vel=0.4
d track=1 step=12 vel=0.4
# Shaker: busier 16ths
d track=2 step=0 vel=0.25
d track=2 step=1 vel=0.1
d track=2 step=2 vel=0.2
d track=2 step=3 vel=0.1
d track=2 step=4 vel=0.25
d track=2 step=5 vel=0.1
d track=2 step=6 vel=0.2
d track=2 step=7 vel=0.1
d track=2 step=8 vel=0.25
d track=2 step=9 vel=0.1
d track=2 step=10 vel=0.2
d track=2 step=11 vel=0.1
d track=2 step=12 vel=0.25
d track=2 step=13 vel=0.1
d track=2 step=14 vel=0.2
d track=2 step=15 vel=0.1
# Bongo: offbeat accents
d track=3 step=2 vel=0.35
d track=3 step=6 vel=0.3
d track=3 step=10 vel=0.35
d track=3 step=14 vel=0.25
# Bass: IV-V walk, more motion
m track=0 step=0 note=F3 vel=0.55 gate=4
m track=0 step=4 note=A3 vel=0.5 gate=2 slide
m track=0 step=6 note=G3 vel=0.5 gate=2
m track=0 step=8 note=C3 vel=0.55 gate=4
m track=0 step=12 note=E3 vel=0.5 gate=2
m track=0 step=14 note=G3 vel=0.45 gate=2 slide
# Recorder: higher, joyful
m track=1 step=0 note=C6 vel=0.55 gate=4
m track=1 step=4 note=D6 vel=0.5 gate=2
m track=1 step=6 note=E6 vel=0.5 gate=2
m track=1 step=8 note=D6 vel=0.5 gate=4
m track=1 step=12 note=C6 vel=0.5 gate=2
m track=1 step=14 note=B5 vel=0.45 gate=2
# DX7 chords: IV-ii-V-I changes
m track=2 step=0 note=F4 vel=0.4 gate=3
m track=2 step=0 note=A4 vel=0.4 gate=3
m track=2 step=0 note=C5 vel=0.4 gate=3
m track=2 step=4 note=A3 vel=0.35 gate=3
m track=2 step=4 note=C4 vel=0.35 gate=3
m track=2 step=4 note=E4 vel=0.35 gate=3
m track=2 step=8 note=D4 vel=0.4 gate=3
m track=2 step=8 note=F4 vel=0.4 gate=3
m track=2 step=8 note=A4 vel=0.4 gate=3
m track=2 step=12 note=G3 vel=0.4 gate=3
m track=2 step=12 note=B3 vel=0.4 gate=3
